{
  "name": "@notareum/sdk",
  "version": "0.0.0-development",
  "description": "Official TypeScript SDK for the Notareum Protocol -- .nota files, on-chain registry, verification, staking, governance, and fees.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run lint && npm run test && npm run build"
  },
  "license": "MIT",
  "author": "Notareum Labs <research@notareum.com>",
  "homepage": "https://notareum.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notareum/notareum-ts-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/notareum/notareum-ts-sdk/issues"
  },
  "keywords": [
    "notareum",
    "nota",
    "blockchain",
    "web3",
    "ethereum",
    "ethers",
    "sdk",
    "typescript",
    "verification",
    "provenance",
    "staking",
    "governance",
    "rwa"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/node": "^22.10.2",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "semantic-release": "^24.2.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
