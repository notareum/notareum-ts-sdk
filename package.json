{
  "name": "@notareum/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for interacting with the Notareum Protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
