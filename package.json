  },
  "keywords": [
    "notareum",
    "nota",
    "blockchain",
    "web3",
    "sdk",
    "typescript"
  ],
  "dependencies": {
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
